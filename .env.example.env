# ── Deployer wallet ───────────────────────────────────────────────────────────
# Export your private key from MetaMask: Account Details → Export Private Key
# NEVER commit this file to git.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── RPC endpoints (free tiers available at Alchemy / Infura / QuickNode) ──────
ETH_MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETH_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
POLYGON_MAINNET_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_AMOY_RPC=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY

# ── Block explorer API keys (for contract verification) ───────────────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_KEY
BSCSCAN_API_KEY=YOUR_BSCSCAN_KEY
ARBISCAN_API_KEY=YOUR_ARBISCAN_KEY
BASESCAN_API_KEY=YOUR_BASESCAN_KEY
SNOWTRACE_API_KEY=YOUR_SNOWTRACE_KEY

# ── Collection configuration ──────────────────────────────────────────────────
NFT_NAME=My NFT Collection
NFT_SYMBOL=MNFT
# Upload your collection-level JSON to IPFS first (see README), then paste URI:
CONTRACT_URI=ipfs://YOUR_CONTRACT_METADATA_CID
MAX_SUPPLY=0
MAX_PER_WALLET=0
ROYALTY_BPS=500